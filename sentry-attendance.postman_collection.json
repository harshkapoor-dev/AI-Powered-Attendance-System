              "raw": "{\n  \"contents\": [\n    { \"role\": \"user\", \"parts\": [{ \"text\": \"who came late today\" }] },\n    { \"role\": \"model\", \"parts\": [{ \"text\": \"```json\\n{ \\\"tool\\\": \\\"get_late_arrivals\\\", \\\"args\\\": { \\\"date\\\": \\\"2026-05-05\\\", \\\"threshold_hour\\\": 9 } }\\n```\" }] },\n    {\n      \"role\": \"user\",\n      \"parts\": [{\n        \"text\": \"TOOL RESULT for get_late_arrivals:\\n```json\\n[\\n  { \\\"name\\\": \\\"Riya Sharma\\\", \\\"punch_in\\\": \\\"09:42\\\" },\\n  { \\\"name\\\": \\\"Aman Verma\\\", \\\"punch_in\\\": \\\"10:15\\\" }\\n]\\n```\\n\\nNow answer the original question concisely.\"\n      }]\n    }\n  ],\n  \"generationConfig\": { \"temperature\": 0.3 }\n}"
