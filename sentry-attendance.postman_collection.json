    {
      "name": "Reports",
      "description": "PDF and Excel export endpoints. Returns binary file streams; Postman will offer to save the response.",
      "item": [
        {
          "name": "Attendance — Excel",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reports/attendance.xlsx?start_date=2026-04-01&end_date=2026-05-05",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "attendance.xlsx"],
              "query": [
                { "key": "start_date", "value": "2026-04-01" },
                { "key": "end_date", "value": "2026-05-05" }
              ]
            },
            "description": "Excel export. Scoped by role: employee = own, manager = team, admin = all.\n\nResponse is a binary `application/vnd.openxmlformats-officedocument.spreadsheetml.sheet` stream."
          },
          "response": []
