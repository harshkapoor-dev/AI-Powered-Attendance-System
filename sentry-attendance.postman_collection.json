          "name": "Generate Content (follow-up with tool result)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "https://generativelanguage.googleapis.com/v1beta/models/{{model}}:generateContent?key={{geminiKey}}",
              "protocol": "https",
              "host": ["generativelanguage", "googleapis", "com"],
              "path": ["v1beta", "models", "{{model}}:generateContent"],
              "query": [{ "key": "key", "value": "{{geminiKey}}" }]
