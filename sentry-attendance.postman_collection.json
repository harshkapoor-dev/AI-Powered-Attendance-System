        {
          "name": "Attendance — PDF",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reports/attendance.pdf?start_date=2026-04-01&end_date=2026-05-05",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "attendance.pdf"],
              "query": [
                { "key": "start_date", "value": "2026-04-01" },
                { "key": "end_date", "value": "2026-05-05" }
              ]
            },
            "description": "PDF export. Returns `application/pdf`."
